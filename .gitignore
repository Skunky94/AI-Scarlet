# === Progetto Scarlet — Git Ignore ===

# Variabili d'ambiente (API keys)
.env
.env.local
.env.*.local

# Dati persistenti Docker
.letta/
.ollama/

# Agent ID (generato da Letta, unico per istanza)
.agent_id

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
ENV/

# Log e output temporanei
*.log
scripts/*.txt

# Archival memory export (troppo grande, contiene embeddings)
config/archival_memory.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
